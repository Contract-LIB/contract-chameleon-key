;      true
;      (and
;        (= (absState this) (old (absState this)))
;        (= (absValue this) value)
;      )
;    ))
;)

; Setter
(define-contract alias.BadAliasAbstraction.setBoth
    (
      (this (inout BadAliasAbstraction))
      (value (in Int))
    )
    ((
      true
      (and
        (= (absState this) value)
        (= (absValue this) value)
      )
    ))
)

; Bad Alias Contract
(define-contract alias.BadAliasAbstraction.invalid
    (
      (this (inout BadAliasAbstraction))
      (value (in (Ref BadAliasAbstraction)))
    )
    ((
      (= (absValue this) 10)
      (and 
        (= (absState this) 10)
        (= (absValue this) 10)
      )
    ))
)
