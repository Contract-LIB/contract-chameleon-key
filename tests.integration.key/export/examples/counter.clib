(declare-abstractions
  (
    (examples.Counter 0)
  )
  (
    ((Counter (absVal Int)))
  )
)

(define-contract examples.Counter.init
    (
      (result (out Counter))
    )
    ((
      true
      (= (absVal result) 0)
    ))
)

(define-contract examples.Counter.value
  (
    (this (in Counter))
    (result (out Int))
  )
  ((
    true
    (= result (absVal this))
  ))
)

(define-contract examples.Counter.increment
  (
    (this (inout Counter))
  )
  ((
    true
    (= (absVal this) (+ (old (absVal this)) 1))
  ))
)

(define-contract examples.Counter.decrement
  (
    (this (inout Counter))
  )
  ((
    (< 0 (absVal this))
    (= (absVal this) (- (old (absVal this)) 1))
  )
))

(define-contract examples.Counter.set
  (
    (this (inout Counter))
    (value (in Int))
  )
  ((
    true
    (= (absVal this) value)
  ))
)


(define-contract examples.Counter.reset
  (
    (this (inout Counter))
  )
  ((
    true
    (= (absVal this) 0)
  ))
)
